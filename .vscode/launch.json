    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Expo Web - Experimental",
            "request": "launch",
            "type": "reactnativedirect",
            "cwd": "${workspaceFolder}",
            "platform": "expoweb",
            "browserTarget": "edge",
            "url": "http://localhost:8081"
        },
        {
            "command": "npm start",
            "name": "Run npm start",
            "request": "launch",
            "type": "node-terminal"
        },
        {
            "command": "npx expo --web",
            "name": "Run Web",
            "request": "launch",
            "type": "node-terminal"
        },
    ]
}